# TFLOPS Configuration Environment Example
# Copy this to .env (root), website/.env.local, and plugin/.env

# --- Global / API (Go) ---
# For PostgreSQL (Production): postgres://user:pass@host:port/dbname?sslmode=disable
# For SQLite (Local): tflops.db
DATABASE_URL=tflops.db

# --- Website (Next.js) ---
# Public API URL for the frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Plugin (Rust) ---
# Destination for automated census submissions
TFLOPS_API_URL=http://localhost:8000/report
